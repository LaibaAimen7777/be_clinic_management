// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Patient {
  id            Int      @id @default(autoincrement())
  name          String
  age           Int
  relativeType  String
  relativeName  String
  cnicOrMrNo    String @db.VarChar(20)
  date          DateTime
  status        String
  createdAt     DateTime @default(now())
  prescriptions Prescription[]
}

model Medicine {
  id        Int      @id @default(autoincrement())
  name      String
  type      String
  createdAt DateTime @default(now())
}

model Prescription {
  id         Int      @id @default(autoincrement())
  patientId  Int
  patient    Patient  @relation(fields: [patientId], references: [id])
  
  // Eye Examination
  vaRight    String?
  vaLeft     String?
  iopRight   String?
  iopLeft    String?
  atRight    String?
  atLeft     String?
  antSeg     String?
  fundus     String?

  // Systemic History
  dm         Boolean  @default(false)
  htn        Boolean  @default(false)
  ihd        Boolean  @default(false)
  asthma     Boolean  @default(false)

  medicines  Json
  diagnosis  String?
  treatment  String?
  createdAt  DateTime @default(now())
}